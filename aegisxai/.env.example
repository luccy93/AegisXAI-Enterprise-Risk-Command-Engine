# AegisXAI Environment Configuration
# Copy this file to .env and fill in your values

# Authentication
AUTH_SECRET_KEY=your-secret-key-change-in-production

# Database (optional — app uses CSV by default)
DATABASE_URL=sqlite:///aegisxai.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=aegisxai/logs/app.log

# Streamlit
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_MAX_UPLOAD_SIZE=200

# API Keys (if using external services)
# OPENAI_API_KEY=sk-...
# SENDGRID_API_KEY=...
